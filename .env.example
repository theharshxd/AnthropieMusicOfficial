# ── Telegram ─────────────────────────────────────────────────────────────────
# Get from @BotFather
BOT_TOKEN=

# Get from https://my.telegram.org
API_ID=
API_HASH=

# Assistant userbot session string
# Generate with: python generate_session.py
SESSION_STRING=

# ── Owner / Sudo ──────────────────────────────────────────────────────────────
# Your Telegram user ID (get from @userinfobot)
OWNER_ID=

# Comma-separated list of sudo user IDs (optional)
SUDO_USERS=

# ── MongoDB ───────────────────────────────────────────────────────────────────
# MongoDB Atlas free M0 connection string
# Format: mongodb+srv://user:password@cluster.mongodb.net/
MONGO_URI=

# Optional — default is anthropie_music
DB_NAME=anthropie_music

# ── Web Server ────────────────────────────────────────────────────────────────
# Render sets this automatically — leave blank locally or set to 8080
PORT=8080
